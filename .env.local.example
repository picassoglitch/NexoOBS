# Nexo-AI World Supabase project — same backend NexoClip + the web app use.
# These are PUBLIC keys (anon role) — safe to ship in the mobile bundle.
# Copy to .env.local (gitignored) and Expo will inline them as
# process.env.EXPO_PUBLIC_* at build time.

EXPO_PUBLIC_SUPABASE_URL=https://uqcbziwdgbnzehipzjxp.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# The slug NexoOBS registers itself under in the engines registry. Used to
# check profiles.selected_engine_id when gating live access (Phase 1+).
EXPO_PUBLIC_ENGINE_SLUG=nexoobs
