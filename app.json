{
  "expo": {
    "name": "NexoStreamOBS",
    "slug": "nexo-ai-world",
    "version": "0.1.0",
    "scheme": "nexoaiworld",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexoai.world",
      "infoPlist": {
        "NSCameraUsageDescription": "NexoStreamOBS uses the camera to preview and stream live video.",
        "NSMicrophoneUsageDescription": "NexoStreamOBS captures microphone audio for your live stream.",
        "NSLocalNetworkUsageDescription": "NexoStreamOBS connects to your local broadcast/ingest servers on your LAN."
      }
    },
    "android": {
      "package": "com.nexoai.world",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NexoStreamOBS to access the camera",
          "microphonePermission": "Allow NexoStreamOBS to access the microphone",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      "expo-dev-client",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b8c4e4e-f3e6-4645-8a5a-7d85f528d3cf"
      }
    }
  }
}
