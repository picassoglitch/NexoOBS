# Copy to .env.local (gitignored). In Railway, add these to the service's
# Variables tab. Naming follows the Nexo-AI World shared convention
# (NEXO_AI_*, NEXOCLIP_*, NEXOCRYPTO_*, NEXOOBS_*).
#
# NexoOBS is an agent of Nexo-AI World: users log in at nexo-ai.world,
# Nexo-AI mints a 5-min HMAC-signed SSO token, the browser lands on
# /auth/sso?token=... here, which sets our session cookie and bounces to
# /dashboard. There are NO Supabase credentials in NexoOBS — auth is
# delegated entirely to Nexo-AI.

# Shared with Nexo-AI's NEXOOBS_SSO_SECRET. HMAC-SHA256 over the SSO token.
# Generate with: openssl rand -hex 32
NEXOOBS_SSO_SECRET=

# Shared with Nexo-AI's NEXOOBS_ADMIN_TOKEN. Bearer for /api/admin/* calls
# (POST /api/admin/tenants and /:id/status). Generate with: openssl rand -hex 32
NEXOOBS_ADMIN_TOKEN=

# Independent secret — NexoOBS's own session cookie HMAC. NOT shared.
# Rotating this invalidates every active session. Generate with:
#   openssl rand -hex 32
NEXOOBS_SESSION_SECRET=

# Absolute public URL of this deploy. Used to build return_to on the
# login redirect to Nexo-AI.
#   Locally: http://localhost:3000
#   Railway: https://<your-service>.up.railway.app
NEXOOBS_PUBLIC_URL=http://localhost:3000

# Where to send unauthenticated visitors. Make this a SHARED variable in
# the Railway project so every Nexo engine points at the same login.
NEXO_AI_LOGIN_URL=https://nexo-ai.world/login

# ── Per-tenant data store (shared Nexo-AI World Supabase) ──────────────
# NexoOBS reads/writes its nexoobs_* tables here, scoped by tenant_id.
# Server-side only. Apply migration 0023 in the nexo-ai repo first.
#
# Use the NEW-format SECRET key (sb_secret_...) from
# Supabase → Project Settings → API Keys → Secret keys. It replaces the
# legacy service_role JWT and bypasses RLS (tenant scoping is enforced in
# code). Do NOT use the publishable key here.
NEXOOBS_SUPABASE_URL=https://uqcbziwdgbnzehipzjxp.supabase.co
NEXOOBS_SUPABASE_SECRET_KEY=

# ── Relay (nexoclip-live MediaMTX) ─────────────────────────────────────
# The reachable RTMP endpoint encoders push to. For a Railway service this
# is the TCP-proxy host:port (NOT the HTTP custom domain — RTMP is raw TCP
# and Railway custom domains only carry HTTP). Example:
#   rtmp://acela.proxy.rlwy.net:26151/live
NEXOOBS_RELAY_RTMP_URL=rtmp://ingest.nexo-ai.world/live

# Shared bearer the relay presents on /api/internal/live/* — must equal the
# relay service's NEXOCLIP_INTERNAL_SIGNING_SECRET. This is how the relay
# authorizes a stream key and fetches the tenant's fan-out destinations.
NEXOOBS_RELAY_SECRET=

# Live preview: the relay's PRIVATE HLS address on Railway's internal
# network (MediaMTX hls port). NexoOBS proxies it to the authenticated
# tenant via /api/preview — the relay's HLS is never exposed publicly, so
# the stream key never rides in a browser URL. Use the .railway.internal
# hostname of the relay service. Unset → preview shows "no disponible".
#   e.g. http://nexoclip-live.railway.internal:8888
NEXOOBS_RELAY_INTERNAL_HLS=

# ── NexoClip handoff ("Get Clips") ─────────────────────────────────────
# When a tenant has Get Clips on, NexoOBS forwards the stream's
# started/ended lifecycle to NexoClip so the recording runs through
# NexoClip's auto-clip pipeline.
#   NEXOCLIP_INTERNAL_URL    base of NexoClip's internal API
#   NEXOCLIP_INTERNAL_SECRET bearer == NexoClip's NEXOCLIP_INTERNAL_SIGNING_SECRET
#                            (same value shared by relay + NexoClip + NexoOBS)
#   NEXOCLIP_PUBLIC_URL      where the Get Clips button opens
NEXOCLIP_INTERNAL_URL=https://nexoclip.nexo-ai.world
NEXOCLIP_INTERNAL_SECRET=
NEXOCLIP_PUBLIC_URL=https://nexoclip.nexo-ai.world
