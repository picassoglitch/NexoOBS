# Copy to .env.local (gitignored). In Railway, add these to the service's
# Variables tab — they follow the Nexo-AI World shared naming convention
# (NEXO_AI_*, NEXOCLIP_*, NEXOCRYPTO_*, NEXOOBS_*) so they don't collide
# across services in the same project.
#
# No NEXT_PUBLIC_ prefix needed: every read happens on the server (Server
# Actions for OAuth init, @supabase/ssr clients in Server Components and
# middleware). The Supabase URL + anon key never reach the browser bundle.

# Nexo-AI World Supabase project — shared with the React Native app at
# https://supabase.com/dashboard/project/uqcbziwdgbnzehipzjxp
NEXOOBS_SUPABASE_URL=https://uqcbziwdgbnzehipzjxp.supabase.co
NEXOOBS_SUPABASE_ANON_KEY=

# Public base URL used for OAuth redirect (Google → /auth/callback).
# Locally: http://localhost:3000
# Railway:  https://<your-service>.up.railway.app
NEXOOBS_SITE_URL=http://localhost:3000
